# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- LLM: Gemini (primary) ---
# Get at https://aistudio.google.com/apikey  (free tier)
GEMINI_API_KEY=

# --- LLM: Groq (fallback) ---
# Get at https://console.groq.com/keys  (free tier)
GROQ_API_KEY=

# --- Web search ---
# DuckDuckGo via duck-duck-scrape. No key required; no quota.
# Library scrapes html.duckduckgo.com — may break if DDG changes layout.

# --- Supabase ---
# Project URL + anon key + service-role key
# https://supabase.com/dashboard  (free tier 500MB)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (rate limit) ---
# https://console.upstash.com  (free tier 10K commands/day)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Feature flags ---
# Skip rate limit + signature compute in local dev: true|false
DISABLE_RATE_LIMIT=false
